        {
          "src": "/icons/emergency-shortcut.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 480
  },
  "share_target": {
    "action": "/api/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "healthData",
          "accept": ["text/csv", ".csv", "application/json", ".json"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "healthchain",
      "url": "/app?data=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/app/import",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      }
    }
  ]
}
