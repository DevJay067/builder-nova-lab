  "shortcuts": [
    {
      "name": "B-max AI Assistant",
      "short_name": "AI Assistant",
      "description": "Quick access to AI health assistant",
      "url": "/bmax",
      "icons": [
        {
          "src": "/icons/ai-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Health Monitoring", 
      "short_name": "Monitoring",
      "description": "Real-time health monitoring dashboard",
      "url": "/monitoring",
      "icons": [
        {
          "src": "/icons/monitor-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Emergency First Aid",
      "short_name": "Emergency",
