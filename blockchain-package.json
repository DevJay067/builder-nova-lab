{
  "name": "healthchain-blockchain",
  "version": "1.0.0",
  "description": "Blockchain infrastructure for HealthChain secure medical records",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "verify": "hardhat verify --network sepolia",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "size": "hardhat size-contracts",
    "flatten": "hardhat flatten contracts/HealthRecordRegistry.sol > flattened.sol"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "ethers": "^6.7.1",
    "web3.storage": "^4.5.4",
    "@supabase/supabase-js": "^2.38.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "multer": "^1.4.5-lts.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.2",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "@openzeppelin/hardhat-upgrades": "^1.28.0",
    "hardhat": "^2.17.1",
    "hardhat-gas-reporter": "^1.0.9",
    "hardhat-contract-sizer": "^2.10.0",
    "solidity-coverage": "^0.8.4",
    "@typechain/hardhat": "^8.0.3",
    "@typechain/ethers-v6": "^0.4.3",
    "typechain": "^8.3.1",
    "chai": "^4.3.8",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "typescript": "^5.1.6",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "prettier": "^3.0.1",
    "prettier-plugin-solidity": "^1.1.3"
  },
  "keywords": [
    "blockchain",
