# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/health_analytics

# JWT secret
JWT_SECRET=super-long-random-secret-change-me

# Optional end-to-end encryption key for JWE (must be 32+ chars for A256GCM)
ENCRYPTION_KEY=32_bytes_minimum_secret_for_demo________

# Redis URL (optional but recommended)
REDIS_URL=redis://localhost:6379

# Google Maps Places API key (for nearby hospitals)
GOOGLE_MAPS_API_KEY=your_google_maps_key